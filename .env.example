# ───────────────────────────────────────────────────────────────
# The QR Gate — env. Copy to .env.local and fill from the Supabase +
# Stripe + Resend dashboards. NEVER commit .env.local. In production,
# set these in the Vercel project's Environment Variables. Keys only
# here — never real values.
# ───────────────────────────────────────────────────────────────

# Public site URL (the app's domain). Used for auth redirects, OG, sitemap.
NEXT_PUBLIC_SITE_URL=
# Public origin encoded into hosted QR codes (/q/[slug]) and tracked
# links (/r/[slug]). Falls back to NEXT_PUBLIC_SITE_URL, then localhost.
NEXT_PUBLIC_APP_URL=

# Supabase (this app's dedicated project)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server-only — NEVER expose to the client

# Stripe (this app's dedicated account) — OPTIONAL. The free plan,
# auth, publishing, and analytics all work without these.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=           # the $10/mo recurring Price id (server-only)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Analytics — server-only salt for the daily one-way visitor hash
# (approximate unique scans). Set a long random value in production.
ANALYTICS_HASH_SECRET=

# Resend (shared account, per-app API key) — OPTIONAL. Emails are
# silently skipped when unset; nothing else breaks.
RESEND_API_KEY=
RESEND_FROM_EMAIL=                  # e.g. "The QR Gate <hello@yourdomain.com>"
