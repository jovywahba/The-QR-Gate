# ───────────────────────────────────────────────────────────────
# Halfstack app env. Copy to .env.local and fill from the Apple Note /
# Supabase + Stripe + Resend dashboards. NEVER commit .env.local.
# In production, set these in the Vercel project's Environment Variables.
# ───────────────────────────────────────────────────────────────

# Public site URL (the app's domain). Used for auth redirects, OG, sitemap.
NEXT_PUBLIC_SITE_URL=

# Public origin encoded into hosted QR codes (/q/[slug]). Falls back to
# NEXT_PUBLIC_SITE_URL, then http://localhost:3000 in dev. Never hardcode.
NEXT_PUBLIC_APP_URL=

# Supabase (this app's dedicated project)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server-only — NEVER expose to the client

# Stripe (this app's dedicated account in the Halfstack org)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PRICE_ID=        # the Price for this app's plan

# Resend (shared account, per-app API key)
RESEND_API_KEY=
EMAIL_FROM=                         # e.g. "Template Tool <hello@example.com>"
